# *.csv
# *.tsv
# *.parquet
# *.npz
# *.npy

# Build / packaging leftovers
*.egg
*.egg-info/
dist/
build/
pip-wheel-metadata/

# Docker
docker-compose.override.yml

# Notebook exports / reports
*.html
*.pdf

# Misc
*.tmp
*.bak
*.swp