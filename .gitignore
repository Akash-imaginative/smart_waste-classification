# -*- gitignore for Waste-Classification project -*-

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# Virtual environments - Users create their own locally
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Jupyter / notebooks
.ipynb_checkpoints
*.ipynb_checkpoints
jupyter_runtime/
jupyter_cache/

# IPython
profile_default/
ipython_config.py

# Type checkers / caches
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini
Icon?
.Spotlight-V100/
.Trashes/
ehthumbs.db

# OneDrive / temp Office files
~$*
*.lnk

# Logs and databases
*.log
*.sql
*.sqlite3
*.db
*.db-journal

# Sensitive / env files
.env
.env.*
secrets.*
credentials.json
client_secrets.json
*.pem
*.key

# ========================================
# ONLY EXCLUDE: DATASET & CONFUSION MATRIX IMAGES
# ========================================

# Dataset directories (DO NOT PUSH)
data/
datasets/
raw_data/
processed_data/
garbage_classification/
train/
val/
test/

# Confusion matrix images only (DO NOT PUSH)
evaluation_results_consolidated/*.png
evaluation_results_consolidated/*.jpg
evaluation_results_consolidated/*.jpeg

# ========================================
# EVERYTHING ELSE WILL BE PUSHED
# ========================================
# Models - KEPT
# Backend - KEPT  
# Frontend - KEPT
# venv/ - kept (users should create their own)
# node_modules - kept (users should npm install)
# All Python source code - KEPT
pip-wheel-metadata/

# Docker
docker-compose.override.yml

# Notebook exports / reports
*.html
*.pdf

# Misc
*.tmp
*.bak
*.swp